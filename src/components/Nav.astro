---
import { pages } from '../config/pages';

const pathname = Astro.url.pathname;

const links = pages.filter((p) => p.path !== '/');

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
}
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-40 h-16 transition-[background-color,border-color] duration-base"
  data-scrolled="false"
>
  <div class="mx-auto max-w-container h-full px-6 sm:px-8 flex items-center justify-between">
    <a
      href="/"
      class="flex items-center gap-3 font-mono text-nav text-fg no-underline"
      aria-label="Shahir Ahmed — home"
    >
      <span class="text-accent text-nav leading-none select-none" aria-hidden="true">◢</span>
      <span class="tracking-[0.08em] hidden sm:inline">SHAHIR.AHMED</span>
    </a>

    <nav aria-label="Primary">
      <ul class="flex items-center gap-5 sm:gap-8 list-none m-0 p-0">
        {links.map(({ path, label }) => (
          <li>
            <a
              href={path}
              class:list={['nav-link', { active: isActive(path) }]}
              aria-current={isActive(path) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  if (nav) {
    const update = () => {
      nav.dataset.scrolled = String(window.scrollY >= 8);
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
