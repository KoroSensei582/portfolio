---
import Badge from './Badge.astro';

interface Props {
  index: number;
  title: string;
  summary: string;
  status: 'complete' | 'in-progress' | 'ongoing';
  role: string;
  tools: string[];
  date: Date;
  revealIndex?: number;
  headingLevel?: 2 | 3;
}

const { index, title, summary, status, role, tools, date, revealIndex, headingLevel = 3 } = Astro.props;
const year = date.getFullYear();
const num = String(index).padStart(2, '0');
const Heading = headingLevel === 2 ? 'h2' : 'h3';
---

<article
  class:list={[
    'border-t border-rule py-10 grid gap-6 md:gap-8 grid-cols-[auto_1fr] md:grid-cols-[160px_1fr]',
    { 'reveal-item': revealIndex !== undefined },
  ]}
  style={revealIndex !== undefined ? `--i: ${revealIndex};` : undefined}
>
  <div class="flex flex-col gap-4 md:gap-5">
    <span
      class="font-display text-index text-accent leading-none"
      style="font-variation-settings: 'opsz' 96, 'wdth' 85"
      aria-hidden="true"
    >
      {num}
    </span>
    <div class="flex flex-col gap-1">
      {status === 'complete' ? (
        <>
          <span class="font-mono text-micro uppercase text-fg-muted">Complete</span>
          <span class="font-mono text-micro uppercase text-fg-muted">{year}</span>
        </>
      ) : (
        <>
          <Badge status={status} />
          <span class="font-mono text-micro uppercase text-fg-muted mt-1">{year}</span>
        </>
      )}
    </div>
  </div>

  <div class="min-w-0">
    <Heading
      class="font-display text-h3 text-fg m-0 mb-3 text-balance"
      style="font-variation-settings: 'opsz' 48"
    >
      {title}
    </Heading>
    <p class="font-mono text-lede text-fg-secondary m-0 max-w-ch60">
      {summary}
    </p>
    <div class="meta-cluster mt-5">
      <span>ROLE / {role}</span>
      <span>TOOLS / {tools.join(', ')}</span>
    </div>
  </div>
</article>
