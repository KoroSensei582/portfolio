---
import Layout from '../layouts/Layout.astro';
import TickRule from '../components/TickRule.astro';
---

<Layout
  title="Research — Shahir Ahmed"
  description="Undergraduate research in electrochemical sensing and microelectronics at Michigan State University."
>
  <TickRule />

  <div class="mx-auto max-w-container px-6 sm:px-8 pt-16 pb-28">
    <div class="max-w-prose">
      <div class="coord-line mb-10">
        <span>[&nbsp;00.03&nbsp;]&nbsp;&nbsp;RESEARCH</span>
        <span class="hidden sm:inline">LAT 42.7370°N&nbsp;&nbsp;LON 84.4839°W</span>
        <span class="sm:hidden">42.7370°N / 84.4839°W</span>
      </div>

      <h1
        class="font-display text-h1 text-fg m-0 mb-12 text-balance"
        style="font-variation-settings: 'opsz' 72"
      >
        Research<span class="text-accent">.</span>
      </h1>

      <div class="font-mono text-body text-fg-secondary space-y-10 max-w-ch60">
        <section>
          <h2 class="font-mono text-micro text-fg-muted uppercase m-0 mb-4">
            / CURRENT WORK
          </h2>
          <p>
            Undergraduate researcher in the Microtechnology Lab at Michigan State,
            running electrochemical experiments — cyclic voltammetry, differential-pulse
            voltammetry, and fast-scan cyclic voltammetry — and contributing to the
            development of a microfluidic potentiostat.
          </p>
        </section>

        <section>
          <h2 class="font-mono text-micro text-fg-muted uppercase m-0 mb-4">
            / UURAF 2026
          </h2>
          <p>
            Presented a poster comparing the microstructure and elemental composition
            of authentic versus third-party Apple Lightning connector probes, using
            scanning electron microscopy (SEM) and energy-dispersive X-ray spectroscopy
            (EDS).
          </p>
        </section>

        <section>
          <h2 class="font-mono text-micro text-fg-muted uppercase m-0 mb-4">
            / INTERESTS
          </h2>
          <p>
            RF-photonics, photonic integrated circuits, and microelectronics.
          </p>
        </section>
      </div>
    </div>
  </div>
</Layout>
