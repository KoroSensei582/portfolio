---
import Layout from '../../layouts/Layout.astro';
import TickRule from '../../components/TickRule.astro';
import CoordLine from '../../components/CoordLine.astro';
import Badge from '../../components/Badge.astro';
import HeroMedia from '../../components/HeroMedia.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props { entry: CollectionEntry<'projects'> }
const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, date, status, role, tools, summary, media } = entry.data;
const year = date.getFullYear();

function mediaLabel(i: number) {
  return i === 0 ? 'HERO / MEDIA' : `MEDIA / ${String(i + 1).padStart(2, '0')}`;
}
---

<Layout
  title={`${title} — Shahir Ahmed`}
  description={summary}
>
  <TickRule />

  <div class="mx-auto max-w-container px-6 sm:px-8 pt-16 pb-28">
    <div class="mb-10">
      <a href="/projects" class="btn-ghost">← BACK TO PROJECTS</a>
    </div>

    <CoordLine page="/projects" label="PROJECT" />

    <h1
      class="font-display text-h1 text-fg m-0 mb-8 text-balance"
      style="font-variation-settings: 'opsz' 72"
    >
      {title}<span class="text-accent">.</span>
    </h1>

    <div class="detail-layout">
      <div class="detail-main">
        <p class="font-mono text-lede text-fg-secondary m-0 mb-8 max-w-ch60">
          {summary}
        </p>

        <div class="flex flex-col gap-4 mb-12">
          {status !== 'complete' && <Badge status={status} />}
          <div class="meta-cluster">
            {status === 'complete' && <span>STATUS / COMPLETE</span>}
            <span>YEAR / {year}</span>
            <span>ROLE / {role}</span>
            <span>TOOLS / {tools.join(', ')}</span>
          </div>
        </div>

        <div class="content-prose max-w-ch60">
          <Content />
        </div>
      </div>

      <aside class="detail-media flex flex-col gap-6">
        {media.length === 0 ? (
          Array.from({ length: 3 }).map((_, i) => (
            <HeroMedia aspectRatio="16/9" label={mediaLabel(i)} />
          ))
        ) : (
          media.map((item, i) => (
            <HeroMedia hero={item} aspectRatio="16/9" label={mediaLabel(i)} />
          ))
        )}
      </aside>
    </div>
  </div>
</Layout>

<style>
  .detail-layout {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .detail-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 400px;
      column-gap: 3rem;
      align-items: start;
    }
  }
</style>
